These are the routes your React frontend calls to populate the dashboard — incident list, single incident details, analytics, and the public status page.

routes/incidents.js — dashboard routes (JWT protected)
const jwtAuth = require('../middleware/jwtAuth');

// GET /api/incidents — list all for this team
router.get('/', jwtAuth, async (req, res) => {
  const { status, severity, limit = 20, page = 1 } = req.query;
  const filter = { teamId: req.user.teamId };
  if (status)   filter.status   = status;
  if (severity) filter.severity = severity;

  const incidents = await Incident
    .find(filter)
    .sort({ createdAt: -1 })
    .limit(Number(limit))
    .skip((page - 1) * limit);

  res.json(incidents);
});

// GET /api/incidents/:id — single incident with full timeline
router.get('/:id', jwtAuth, async (req, res) => {
  const incident = await Incident.findOne({
    _id: req.params.id, teamId: req.user.teamId
  });
  if (!incident) return res.status(404).json({ error: 'Not found' });
  res.json(incident);
});

// GET /api/incidents/analytics/mttr — mean time to resolve
router.get('/analytics/mttr', jwtAuth, async (req, res) => {
  const resolved = await Incident.find({
    teamId: req.user.teamId,
    status: 'resolved',
    resolvedAt: { $exists: true }
  });

  if (!resolved.length) return res.json({ mttrMinutes: 0, count: 0 });

  const totalMs = resolved.reduce((sum, i) =>
    sum + (i.resolvedAt - i.createdAt), 0);

  res.json({
    mttrMinutes: Math.round(totalMs / resolved.length / 60000),
    count: resolved.length,
    byService: groupByService(resolved) // helper to group stats per service
  });
});

// GET /api/status/:teamId — PUBLIC, no auth — for the status page
router.get('/status/:teamId', async (req, res) => {
  const activeIncidents = await Incident.find({
    teamId: req.params.teamId,
    status: { $ne: 'resolved' }
  }).select('title severity status affectedServices createdAt');

  const recentHistory = await Incident.find({
    teamId: req.params.teamId,
    status: 'resolved'
  }).sort({ resolvedAt: -1 }).limit(10)
    .select('title severity createdAt resolvedAt affectedServices');

  res.json({
    operational: activeIncidents.length === 0,
    activeIncidents,
    recentHistory
  });
});

