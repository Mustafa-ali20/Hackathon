2. API KEY SYSTEM:

models/ApiKey.js
const mongoose = require('mongoose');
const crypto = require('crypto');

const ApiKeySchema = new mongoose.Schema({
  teamId:   { type: mongoose.Schema.Types.ObjectId, ref: 'Team', required: true },
  keyHash:  { type: String, required: true, unique: true },
  label:    { type: String, default: 'Default key' },
  lastUsed: { type: Date },
  createdAt:{ type: Date, default: Date.now }
});

// Static helper to hash a raw key
ApiKeySchema.statics.hashKey = (rawKey) =>
  crypto.createHash('sha256').update(rawKey).digest('hex');

module.exports = mongoose.model('ApiKey', ApiKeySchema);

routes/apikeys.js — generate and revoke keys
const router  = require('express').Router();
const crypto  = require('crypto');
const ApiKey  = require('../models/ApiKey');
const jwtAuth = require('../middleware/jwtAuth');

// POST /api/apikeys — generate a new key (dashboard user must be logged in)
router.post('/', jwtAuth, async (req, res) => {
  // Generate a random key with a recognisable prefix  e.g. ip_a3f9c2...
  const rawKey = 'ip_' + crypto.randomBytes(32).toString('hex');
  const keyHash = ApiKey.hashKey(rawKey);

  await ApiKey.create({
    teamId: req.user.teamId,
    keyHash,
    label: req.body.label || 'New key'
  });
 // Return raw key ONCE — we never store it, they must copy it now
  res.json({
    key: rawKey,
    message: 'Copy this key now. It will not be shown again.'
  });
});

// GET /api/apikeys — list keys (show label + lastUsed, never the raw key)
router.get('/', jwtAuth, async (req, res) => {
  const keys = await ApiKey.find({ teamId: req.user.teamId })
    .select('-keyHash'); // never expose the hash either
  res.json(keys);
});

// DELETE /api/apikeys/:id — revoke a key
router.delete('/:id', jwtAuth, async (req, res) => {
  await ApiKey.deleteOne({ _id: req.params.id, teamId: req.user.teamId });
  res.json({ ok: true });
});

module.exports = router;

middleware/apiKeyAuth.js — used on every client-facing route
const ApiKey = require('../models/ApiKey');
const Team   = require('../models/Team');

module.exports = async (req, res, next) => {
  const raw = req.headers['x-api-key'];   // client sends: X-API-Key: ip_abc123
  if (!raw) return res.status(401).json({ error: 'Missing X-API-Key header' });

  const hash = ApiKey.hashKey(raw);
  const apiKey = await ApiKey.findOne({ keyHash: hash });
  if (!apiKey) return res.status(401).json({ error: 'Invalid API key' });

  // Update lastUsed silently
  ApiKey.updateOne({ _id: apiKey._id }, { lastUsed: new Date() });

  const team = await Team.findById(apiKey.teamId);
  req.team = team;    // attach team to request for downstream use
  next();
};



3. REPORT ENDPOINT

routes/incidents.js
const router       = require('express').Router();
const Incident     = require('../models/Incident');
const apiKeyAuth   = require('../middleware/apiKeyAuth');
const rateLimiter  = require('../middleware/rateLimiter');
const { detectSeverity } = require('../services/severityDetector');
const { sendNotification } = require('../services/notificationService');
const { getIO }    = require('../socket');

// ─────────────────────────────────────────
// POST /api/incidents/report
// Called by client's backend when something breaks
// ─────────────────────────────────────────
router.post('/report', apiKeyAuth, rateLimiter, async (req, res) => {
  try {
    const {
      title,
      description,
      service,           // e.g. "Payment API"
      severity,          // optional — we auto-detect if missing
      errorRate,         // e.g. 0.45 = 45% errors
      responseTimeMs,    // e.g. 4500
      affectedUsers,     // e.g. 1200
      incidentId,        // if updating an existing incident
      action             // "create" | "update" | "resolve"
    } = req.body;

    const teamId = req.team._id.toString();

    // ── UPDATE existing incident ──────────────────
    if (action === 'update' && incidentId) {
      const incident = await Incident.findOneAndUpdate(
        { _id: incidentId, teamId },
        { $push: { timeline: { message: description, author: service, type: 'auto' } } },
        { new: true }
      );
      getIO().to(teamId).emit('incident:updated', incident);
      return res.json({ ok: true, incident });
    }

    // ── RESOLVE existing incident ─────────────────
    if (action === 'resolve' && incidentId) {
      const incident = await Incident.findOneAndUpdate(
        { _id: incidentId, teamId },
        {
          status: 'resolved',
          resolvedAt: new Date(),
          $push: { timeline: { message: 'Service recovered. Auto-resolved.', author: service, type: 'auto' } }
        },
        { new: true }
      );
      getIO().to(teamId).emit('incident:resolved', incident);
      return res.json({ ok: true, incident });
    }

    // ── CREATE new incident ───────────────────────
    const autoSeverity = severity || detectSeverity({ errorRate, responseTimeMs, affectedUsers });

    const incident = await Incident.create({
      teamId,
      title: title || `${service} is experiencing issues`,
      severity: autoSeverity,
      status: 'investigating',
      source: 'api',
      affectedServices: [service],
      timeline: [{
        message: description || `Incident reported by ${service}`,
        author: service,
        type: 'auto'
      }]
    });

    // Notify via WebSocket AND email/slack
    getIO().to(teamId).emit('incident:new', incident);
    sendNotification(req.team, incident); // fire and forget

    // Return incidentId so client can update/resolve it later
    res.status(201).json({
      ok: true,
      incidentId: incident._id,
      severity: autoSeverity
    });

  } catch (err) {
    console.error(err);
    res.status(500).json({ error: 'Server error' });
  }
});

module.exports = router;



4.AUTO SEVERITY

services/severityDetector.js
// Rules for auto-detecting severity from raw metrics
// Client sends numbers — you return P1 / P2 / P3

module.exports.detectSeverity = ({ errorRate, responseTimeMs, affectedUsers }) => {

  // P1 — Critical. Immediate response needed.
  if (
    errorRate >= 0.5 ||          // 50%+ errors
    responseTimeMs >= 10000 ||   // 10s+ response time
    affectedUsers >= 1000        // 1000+ users impacted
  ) return 'P1';

  // P2 — Major. Investigate quickly.
  if (
    errorRate >= 0.1 ||          // 10%+ errors
    responseTimeMs >= 3000 ||    // 3s+ response time
    affectedUsers >= 100         // 100+ users impacted
  ) return 'P2';

  // P3 — Minor. Monitor it.
  return 'P3';
};

// Example usage:
// detectSeverity({ errorRate: 0.6, responseTimeMs: 1200, affectedUsers: 50 })
// → 'P1'  (because errorRate >= 0.5)
//
// detectSeverity({ errorRate: 0.05, responseTimeMs: 4000, affectedUsers: 20 })
// → 'P2'  (because responseTimeMs >= 3000)
