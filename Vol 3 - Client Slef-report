5.RATE LIMIT

middleware/rateLimiter.js
npm install express-rate-limit
const rateLimit = require('express-rate-limit');

// Each team can call /api/incidents/report max 60 times per hour
module.exports = rateLimit({
  windowMs: 60 * 60 * 1000,   // 1 hour window
  max: 60,
  keyGenerator: (req) => req.team._id.toString(), // per team, not per IP
  handler: (req, res) => {
    res.status(429).json({
      error: 'Rate limit exceeded',
      retryAfter: '1 hour',
      limit: 60,
      tip: 'Use action: update to add details to an existing incident instead of creating new ones'
    });
  },
  standardHeaders: true,
  legacyHeaders: false
});
The keyGenerator must use teamId, not IP address. Multiple services on the same company's server would share an IP and hit limits incorrectly. teamId keeps it per-account.



6. CLINET SDK

This is what makes Pattern B shine in the pitch. Instead of raw fetch() calls, you give clients a tiny SDK they can npm install. This is exactly how Sentry, Datadog, and LogRocket work.

sdk/incident-reporter.js — the SDK you publish (or give as a file)
// This is what clients paste into their project
// They do: const { IncidentReporter } = require('./incident-reporter')
// Or eventually: npm install @yourplatform/reporter

class IncidentReporter {
  constructor({ apiKey, baseUrl = 'https://yourapp.com' }) {
    this.apiKey  = apiKey;
    this.baseUrl = baseUrl;
    this.openIncidents = {}; // tracks incidentId per service
  }

  async _call(body) {
    try {
      const res = await fetch(`${this.baseUrl}/api/incidents/report`, {
        method:  'POST',
        headers: { 'Content-Type': 'application/json', 'X-API-Key': this.apiKey },
        body:    JSON.stringify(body)
      });
      return res.json();
    } catch (e) {
      // SDK never crashes the client app — fail silently
      console.error('[IncidentReporter] Failed to report:', e.message);
    }
  }

  // Start a new incident for a service
  async report(service, description, metrics = {}) {
    const result = await this._call({
      action: 'create', service, description, ...metrics
    });
    if (result?.incidentId) {
      this.openIncidents[service] = result.incidentId;
    }
    return result;
  }

  // Post an update to an ongoing incident
  async update(service, description) {
    const incidentId = this.openIncidents[service];
    if (!incidentId) return;
    await this._call({ action: 'update', service, description, incidentId });
  }

  // Resolve when service recovers
  async resolve(service) {
    const incidentId = this.openIncidents[service];
    if (!incidentId) return;
    await this._call({ action: 'resolve', service, incidentId });
    delete this.openIncidents[service];
  }
}

module.exports = { IncidentReporter };
How the client uses the SDK — 3 lines total
const { IncidentReporter } = require('./incident-reporter');

const reporter = new IncidentReporter({ apiKey: 'ip_abc123...' });

